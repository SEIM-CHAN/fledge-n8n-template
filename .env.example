# PostgreSQL の管理ユーザー。ローカル開発用の初期値です。
POSTGRES_USER=root
# PostgreSQL 管理ユーザーのパスワード。ランダムな文字列を設定します。
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# n8n が接続に使う PostgreSQL ユーザーです。
POSTGRES_NON_ROOT_USER=n8n
# 上記 n8n 用 PostgreSQL ユーザーのパスワード。ランダムな文字列を設定します。
POSTGRES_NON_ROOT_PASSWORD=

# n8n に保存される Credentials の暗号化に使います。運用開始後は変更しません。
N8N_ENCRYPTION_KEY=
# ローカル利用時は変更不要です。Cloudflare Tunnel 公開時は外部URLへ変更します。
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ワークフローで使う既定のタイムゾーンです。
GENERIC_TIMEZONE=Asia/Tokyo
TZ=Asia/Tokyo
